[Unit]
Description=WeChat Distribution Mall
After=network.target mysql.service

[Service]
Type=simple
WorkingDirectory=/opt/mall
Environment=NODE_ENV=production
ExecStart=/usr/bin/node /opt/mall/server.js
Restart=always
RestartSec=3
User=mall
Group=mall
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/mall

[Install]
WantedBy=multi-user.target
