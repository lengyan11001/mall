page {
  min-height: 100%;
  background: #f5f7fb;
  color: #18212f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  margin: 0;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}

button::after {
  border: 0;
}

.page {
  padding: 24rpx;
}

.card {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border: 1rpx solid #dde4ee;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(18, 35, 66, 0.06);
}

.muted {
  color: #667085;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 24rpx;
  background: #0f9f6e;
  color: #ffffff;
  line-height: 1.15;
  white-space: nowrap;
}

.btn.secondary {
  background: #edf2f7;
  color: #18212f;
}

.btn.ghost {
  border: 1rpx solid #bfe3d3;
  background: #ffffff;
  color: #087455;
}

.pill {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #e9f7f1;
  color: #087455;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.15;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pill.warn {
  background: #fff4dd;
  color: #946018;
}

.pill.danger {
  background: #ffe7e3;
  color: #b33c28;
}

.section-title {
  margin: 30rpx 0 16rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  gap: 12rpx;
  justify-content: space-between;
}

.grid-2 {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}

.grid-2 > .tile {
  width: calc(50% - 16rpx);
  margin: 8rpx;
}

.tile {
  min-height: 128rpx;
  padding: 22rpx;
  border: 1rpx solid #dde4ee;
  border-radius: 16rpx;
  background: #ffffff;
}

.tile-label {
  display: block;
  color: #667085;
  font-size: 22rpx;
  font-weight: 700;
}

.tile-value {
  display: block;
  margin-top: 10rpx;
  color: #18212f;
  font-size: 40rpx;
  font-weight: 900;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  color: #18212f;
  font-size: 30rpx;
  font-weight: 900;
}

.empty {
  padding: 48rpx 20rpx;
  border: 1rpx dashed #cbd5e1;
  border-radius: 16rpx;
  color: #667085;
  text-align: center;
}

.product-card {
  overflow: hidden;
  border: 1rpx solid #dde4ee;
  border-radius: 16rpx;
  background: #ffffff;
}

.product-image {
  width: 100%;
  height: 250rpx;
  background: #edf2f7;
}

.product-body {
  padding: 20rpx;
}

.product-title {
  min-height: 72rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
}

.price {
  flex: 0 0 auto;
  color: #ef6f54;
  font-size: 36rpx;
  font-weight: 900;
}

.actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.actions button {
  flex: 1;
  min-width: 0;
  padding-right: 14rpx;
  padding-left: 14rpx;
  font-size: 26rpx;
}

.input {
  width: 100%;
  min-height: 76rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dde4ee;
  border-radius: 14rpx;
  background: #ffffff;
}
