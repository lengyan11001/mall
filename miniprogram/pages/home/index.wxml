<view class="home-hero compact">
  <view class="row between">
    <view class="row user-line">
      <view class="avatar">{{user.avatar || 'WX'}}</view>
      <view>
        <view class="hero-name">{{user.nickname || '微信用户'}}</view>
        <view class="hero-sub">{{relationText}}</view>
      </view>
    </view>
    <button class="login-btn" bindtap="syncProfile">同步资料</button>
  </view>
</view>

<view class="page overlap">
  <view wx:if="{{loading}}" class="empty">正在加载活动商品</view>

  <view wx:elif="{{campaign}}" class="campaign-detail card">
    <image class="campaign-cover" wx:if="{{campaign.share_cover || campaign.product.images[0]}}" src="{{campaign.share_cover || campaign.product.images[0]}}" mode="aspectFill"></image>
    <view class="detail-head">
      <view class="detail-copy">
        <view class="entry-kicker">拓客宝活动</view>
        <view class="detail-title">{{campaign.name}}</view>
        <view class="desc">{{campaign.description || campaign.product.title}}</view>
      </view>
      <text class="pill warn">拓客宝</text>
    </view>

    <view class="metric-row">
      <view>
        <text>活动价</text>
        <text class="metric-value">¥{{campaign.lead_price}}</text>
      </view>
      <view>
        <text>销量</text>
        <text class="metric-value">{{campaign.sold_count + campaign.virtual_sold_count}}</text>
      </view>
      <view>
        <text>限购</text>
        <text class="metric-value">{{campaign.per_user_limit || '不限'}}</text>
      </view>
    </view>

    <view class="sub-card compact">
      <view class="section-title compact">关系锁定</view>
      <view class="desc">{{campaign.relation_mode_text}}</view>
      <view class="desc" wx:if="{{campaign.relation.inviter_id}}">当前推荐人 ID：{{campaign.relation.inviter_id}}</view>
    </view>

    <view wx:if="{{campaign.product.detail_html}}" class="sub-card compact">
      <view class="section-title compact">商品详情</view>
      <rich-text class="rich-detail" nodes="{{campaign.product.detail_html}}"></rich-text>
    </view>

    <view wx:if="{{campaignFormSchema.length}}" class="sub-card compact">
      <view class="section-title compact">报名信息</view>
      <view wx:for="{{campaignFormSchema}}" wx:key="key" class="form-line">
        <text>{{item.label}}</text>
        <input class="input" data-key="{{item.key}}" bindinput="onCampaignFieldInput" placeholder="{{item.placeholder || '请输入'}}" />
      </view>
    </view>

    <view wx:if="{{campaign.virtual_rankings.length}}" class="sub-card compact">
      <view class="section-title compact">排行榜</view>
      <view wx:for="{{campaign.virtual_rankings}}" wx:key="nickname" class="rank-row">
        <image wx:if="{{item.avatar}}" src="{{item.avatar}}" mode="aspectFill"></image>
        <view>
          <view class="rank-name">{{item.nickname || '用户'}}</view>
          <view class="desc">邀请 {{item.invite_count || 0}} 人 · 奖励 ¥{{item.reward_amount || 0}}</view>
        </view>
      </view>
    </view>

    <view class="sticky-actions">
      <button class="btn ghost" loading="{{invitePosterLoading}}" bindtap="shareCampaign">{{invitePosterLoading ? '生成中' : '邀请'}}</button>
      <button class="btn" bindtap="buyCampaign">活动下单</button>
    </view>
  </view>

  <view wx:else class="campaign-entry empty-entry">
    <view class="entry-copy">
      <text class="entry-kicker">拓客宝活动</text>
      <text class="entry-title">暂无在架活动</text>
      <text class="entry-desc">后台发布一个拓客宝商品后，小程序首页会直接展示该活动明细。</text>
    </view>
  </view>
</view>

<view wx:if="{{invitePosterVisible}}" class="flow-mask" bindtap="closeInvitePoster">
  <view class="invite-panel" catchtap="noop">
    <view class="flow-head">
      <view class="flow-copy">
        <view class="flow-title">专属邀请</view>
        <view class="desc">海报和二维码带你的推荐关系</view>
      </view>
      <button class="flow-close" bindtap="closeInvitePoster">×</button>
    </view>
    <view class="poster-preview" bindtap="previewInvitePoster">
      <image class="invite-poster" wx:if="{{invitePoster.poster_url}}" src="{{invitePoster.poster_url}}" mode="aspectFit"></image>
    </view>
    <view class="invite-qrcode-card">
      <image wx:if="{{invitePoster.qrcode_url}}" src="{{invitePoster.qrcode_url}}" mode="aspectFit" bindtap="previewInviteQrcode"></image>
      <view>
        <view class="section-title compact">个人二维码</view>
        <view class="desc">扫码直接进活动详情，并按配置建立关系。</view>
      </view>
    </view>
    <view class="invite-actions">
      <button class="btn" bindtap="previewInvitePoster">看海报</button>
      <button class="btn ghost" bindtap="previewInviteQrcode">看码</button>
      <button class="btn secondary" bindtap="copyInvitePath">复制路径</button>
    </view>
  </view>
</view>

<view wx:if="{{orderFlow.visible}}" class="flow-mask" bindtap="noop">
  <view class="flow-panel" catchtap="noop">
    <view class="flow-steps">
      <text class="{{orderFlow.step === 'checkout' || orderFlow.step === 'paying' ? 'active' : ''}}">下单</text>
      <text class="{{orderFlow.step === 'lottery' ? 'active' : ''}}">抽奖</text>
      <text class="{{orderFlow.step === 'traffic' ? 'active' : ''}}">领奖</text>
    </view>

    <block wx:if="{{orderFlow.step === 'checkout' || orderFlow.step === 'paying'}}">
      <view class="flow-head">
        <view class="flow-copy">
          <view class="flow-title">确认订单</view>
          <view class="desc">确认商品信息，支付完成后进入抽奖流程。</view>
        </view>
        <button class="flow-close" bindtap="closeOrderFlow">×</button>
      </view>
      <view class="order-product">
        <image src="{{orderFlow.campaign.share_cover || orderFlow.product.images[0]}}" mode="aspectFill"></image>
        <view>
          <view class="product-title">{{orderFlow.campaign.name}}</view>
          <view class="desc">{{orderFlow.product.title}}</view>
          <view class="row between">
            <text class="price">¥{{orderFlow.campaign.lead_price}}</text>
            <text class="pill warn">x1</text>
          </view>
        </view>
      </view>
      <view class="flow-address">
        <view class="section-title compact">收货地址</view>
        <block wx:if="{{orderFlow.selectedAddress}}">
          <picker mode="selector" range="{{orderFlow.addressLabels}}" bindchange="selectFlowAddress">
            <view class="address-card">
              <view class="row between">
                <view class="address-person">{{orderFlow.selectedAddress.receiver_name}} {{orderFlow.selectedAddress.phone}}</view>
                <text class="pill warn">切换</text>
              </view>
              <view class="desc">{{orderFlow.selectedAddress.full_address}}</view>
            </view>
          </picker>
          <button class="btn secondary address-manage" bindtap="goAddressSettings">管理地址</button>
        </block>
        <view wx:else class="address-card empty-address">
          <view class="desc">还没有收货地址，请先去个人页新增地址。</view>
          <button class="btn" bindtap="goAddressSettings">去编辑地址</button>
        </view>
      </view>
      <view wx:if="{{orderFlow.formSchema.length}}" class="flow-form">
        <view wx:for="{{orderFlow.formSchema}}" wx:key="key" class="form-line">
          <text>{{item.label}}</text>
          <input class="input" data-key="{{item.key}}" bindinput="onFlowFieldInput" value="{{orderFlow.formValues[item.key]}}" placeholder="{{item.placeholder || '请输入'}}" />
        </view>
      </view>
      <button class="btn flow-primary" disabled="{{!orderFlow.selectedAddressId || orderFlow.step === 'paying'}}" loading="{{orderFlow.step === 'paying'}}" bindtap="confirmCampaignPayment">
        {{!orderFlow.selectedAddressId ? '先去编辑地址' : orderFlow.step === 'paying' ? '正在支付' : '确认支付 ¥' + orderFlow.campaign.lead_price}}
      </button>
    </block>

    <block wx:elif="{{orderFlow.step === 'lottery'}}">
      <view class="flow-head">
        <view class="flow-copy">
          <view class="flow-title">支付完成</view>
          <view class="desc">{{orderFlow.campaign.lottery_config.description || '点击转盘开始抽奖。'}}</view>
        </view>
      </view>
      <view class="wheel-wrap">
        <view class="wheel-pointer"></view>
        <view class="wheel" style="{{orderFlow.wheelStyle}}">
          <view wx:for="{{orderFlow.wheelPrizes}}" wx:key="name" class="wheel-prize" style="transform: rotate({{item.angle}}deg) translateY(-145rpx);">
            {{item.shortName}}
          </view>
        </view>
        <button class="wheel-button" disabled="{{orderFlow.wheelSpinning || orderFlow.lotteryDone}}" bindtap="spinLottery">
          {{orderFlow.lotteryDone ? '已开奖' : orderFlow.wheelSpinning ? '抽奖中' : '开始'}}
        </button>
      </view>
      <view wx:if="{{orderFlow.lotteryDone}}" class="lottery-result">
        <text>{{orderFlow.lotteryRecord.prize_name}}</text>
        <view class="desc">{{orderFlow.lotteryRecord.prize_type === 'thanks' ? '感谢参与，继续完成领奖步骤。' : '中奖啦，继续完成领奖步骤。'}}</view>
      </view>
    </block>

    <block wx:elif="{{orderFlow.step === 'traffic'}}">
      <view class="flow-head">
        <view class="flow-copy">
          <view class="flow-title">领奖二维码</view>
          <view class="desc">请长按识别二维码，完成后才能关闭流程。</view>
        </view>
      </view>
      <view wx:if="{{orderFlow.trafficQrcode}}" class="traffic-card">
        <image src="{{orderFlow.trafficQrcode.image_url}}" mode="aspectFit" bindtap="previewTrafficQrcode"></image>
        <view class="flow-title small">{{orderFlow.trafficQrcode.name}}</view>
        <view class="desc">{{orderFlow.trafficQrcode.note}}</view>
        <button class="btn ghost" bindtap="previewTrafficQrcode">识别领奖二维码</button>
      </view>
      <view wx:else class="empty">当前活动未配置领奖二维码，可直接完成。</view>
      <button class="btn flow-primary" disabled="{{!orderFlow.trafficScanned}}" bindtap="finishTrafficFlow">完成并查看订单</button>
    </block>
  </view>
</view>
