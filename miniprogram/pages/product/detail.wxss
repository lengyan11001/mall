.gallery {
  width: 100%;
  height: 520rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #edf2f7;
}

.gallery-image {
  width: 100%;
  height: 520rpx;
}

.detail-head {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  justify-content: space-between;
  margin-top: 22rpx;
}

.detail-title {
  color: #18212f;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.25;
}

.desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.metric-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 22rpx 0;
}

.metric-row > view {
  padding: 16rpx;
  border: 1rpx solid #dde4ee;
  border-radius: 14rpx;
  background: #f8fafc;
}

.metric-row text {
  display: block;
  color: #667085;
  font-size: 22rpx;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  color: #18212f;
  font-size: 30rpx;
  font-weight: 900;
}

.sub-card {
  padding: 18rpx;
  border: 1rpx solid #dde4ee;
  border-radius: 14rpx;
  background: #f8fafc;
}

.section-title.compact {
  margin: 0 0 12rpx;
  font-size: 28rpx;
}

.rich-detail {
  display: block;
  color: #344054;
  font-size: 26rpx;
  line-height: 1.65;
}

.sticky-actions {
  display: flex;
  gap: 14rpx;
  position: sticky;
  bottom: 0;
  margin: 22rpx -24rpx -24rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #dde4ee;
  background: rgba(255, 255, 255, 0.96);
}

.sticky-actions button {
  flex: 1;
}

.poster-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
  background: rgba(15, 23, 42, 0.54);
}

.poster-panel {
  width: 100%;
  max-height: 92vh;
  overflow-y: auto;
  padding: 22rpx;
  border-radius: 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.poster-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.poster-title {
  color: #18212f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.poster-sub {
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
  line-height: 1.2;
}

.icon-btn {
  width: 58rpx;
  min-width: 58rpx;
  height: 58rpx;
  padding: 0;
  border-radius: 999rpx;
  color: #344054;
  font-size: 34rpx;
  line-height: 58rpx;
  background: #f1f5f9;
}

.poster-image {
  display: block;
  width: 100%;
  max-height: 1040rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #f8fafc;
}

.qrcode-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #f8fafc;
}

.qrcode-row image {
  width: 132rpx;
  height: 132rpx;
  flex: 0 0 132rpx;
}

.qrcode-title {
  color: #18212f;
  font-size: 26rpx;
  font-weight: 800;
}

.qrcode-scene {
  margin-top: 8rpx;
  color: #667085;
  font-size: 22rpx;
  word-break: break-all;
}

.poster-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.poster-actions button {
  flex: 1;
  white-space: nowrap;
}
